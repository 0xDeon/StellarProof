# =============================================================================
# StellarProof Backend – Environment Variables
# Copy this file to .env and fill in the values for your environment.
# NEVER commit .env to version control.
# =============================================================================

# --- Server -------------------------------------------------------------------
NODE_ENV=development
PORT=4000

# --- Database -----------------------------------------------------------------
# MongoDB connection string.
# Local: mongodb://localhost:27017/stellarproof
# Atlas:  mongodb+srv://<user>:<pass>@cluster.mongodb.net/stellarproof
MONGODB_URI=mongodb://localhost:27017/stellarproof

# --- Stellar / Soroban RPC ----------------------------------------------------
# Soroban RPC endpoint for NFT ownership simulation calls.
# Testnet:  https://soroban-testnet.stellar.org
# Mainnet:  https://mainnet.stellar.validationcloud.io/v1/<API_KEY>
STELLAR_RPC_URL=https://soroban-testnet.stellar.org

# Network passphrase used when building simulation transactions.
# Testnet: "Test SDF Network ; September 2015"
# Mainnet: "Public Global Stellar Network ; September 2015"
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# (Optional) Name of the balance-query entry point on the Soroban NFT contract.
# Defaults to "balance" (SEP-41 standard). Override only if the deployed
# contract uses a different function name (e.g. "balance_of").
# STELLAR_NFT_BALANCE_FN=balance

# --- CORS ---------------------------------------------------------------------
# Allowed origin for the StellarProof frontend.
CORS_ORIGIN=http://localhost:3000

# --- Logging ------------------------------------------------------------------
# Morgan log format: dev | combined | tiny | short
LOG_LEVEL=dev
